def view_tournament_winners_by_year():
    year = input("Enter year (or press Enter to view all): ")
    conn = connect()
    cursor = conn.cursor()
    if year.strip() == "":
        cursor.execute("""
            SELECT t.Name, t.Year, t.League_Name, t.Winner
            FROM League_Tournament_Has t
            ORDER BY t.Year DESC
        """)
    else:
        cursor.execute("""
            SELECT t.Name, t.Year, t.League_Name, t.Winner
            FROM League_Tournament_Has t
            WHERE t.Year = ?
            ORDER BY t.Year DESC
        """, (year,))
    rows = cursor.fetchall()
    conn.close()
    if not rows:
        print("No tournaments found.")
        return
    print("\n{:<25} {:<6} {:<25} {:<20}".format("Tournament", "Year", "League", "Winner"))
