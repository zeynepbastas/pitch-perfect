# LEAGUE OPTIONS

def view_all_leagues():
    conn = connect()
    cursor = conn.cursor()
    cursor.execute("SELECT * FROM League")
    rows = cursor.fetchall()
    conn.close()
    if not rows:
        print("No leagues found.")
        return
    print("\n{:<30} {:<20} {:<10}".format("League Name", "Country", "# Teams"))
